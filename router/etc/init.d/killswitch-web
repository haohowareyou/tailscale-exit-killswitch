#!/bin/sh /etc/rc.common
# Dedicated uhttpd instance for the toggle page, LAN-only on <LAN_IP>:8090.
# (GL.iNet serves its main UI via nginx on :80; this keeps our CGI isolated from it.)
# Adjust the -p address below if your router LAN IP is not 192.168.8.1.
START=95
STOP=10
USE_PROCD=1
start_service() {
  procd_open_instance
  procd_set_param command /usr/sbin/uhttpd -f -h /etc/killswitch-web -x /cgi-bin -p 192.168.8.1:8090
  procd_set_param respawn
  procd_close_instance
}
