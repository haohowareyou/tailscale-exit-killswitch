# Copy to config.env and fill in. config.env is git-ignored — never commit it.

# SSH target for the router. Use the LAN IP, or its Tailscale IP if you deploy remotely.
ROUTER=root@192.168.8.1

# Tailscale IP of the exit node you want all router traffic to egress through
# (find it with `tailscale status` on the exit-node host).
EXIT_NODE=100.x.y.z

# Router's WAN interface. eth0 on most GL.iNet wired-WAN models; check `ip route`.
WAN_IF=eth0
